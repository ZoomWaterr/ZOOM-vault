filters:
  and:
    - file.inFolder("Python大知识库/30-算法教材")
    - 'file.ext == "md"'
properties:
  file.name:
    displayName: 笔记
  level:
    displayName: 难度
  status:
    displayName: 状态
  priority:
    displayName: 优先级
  aliases:
    displayName: 别名
views:
  - type: table
    name: 算法路线
    order:
      - file.name
      - level
      - status
      - priority
