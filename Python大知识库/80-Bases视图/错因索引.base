filters:
  and:
    - file.inFolder("Python大知识库/50-错因与成长")
    - 'file.ext == "md"'
properties:
  file.name:
    displayName: 笔记
  area:
    displayName: 区域
  kind:
    displayName: 类型
  priority:
    displayName: 优先级
  tags:
    displayName: 标签
views:
  - type: table
    name: 错因与成长
    order:
      - file.name
      - kind
      - priority
      - tags
